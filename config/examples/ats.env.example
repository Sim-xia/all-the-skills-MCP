# All The Skills environment configuration example
#
# Usage:
#   source config/examples/ats.env.example
#   all-the-skills
#
# Or inject these variables from your MCP client / process manager.

# Comma-separated roots scanned for SKILL.md files.
export SKILL_CORTEX_ROOTS="$HOME/.claude/skills,$HOME/.cursor/skills,$HOME/.windsurf/skills,$HOME/.config/opencode/skills,$PWD/.skills,$PWD/.all_the_skills/installed,$PWD/.all_the_skills/fetched"

# Cache file used for the indexed skill snapshot.
export SKILL_CORTEX_CACHE_PATH="$PWD/.skill_cortex_cache/index.json"

# Allowed tags registry.
export SKILL_CORTEX_TAGS_PATH="$PWD/tags.md"
